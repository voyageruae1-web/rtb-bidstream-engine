generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  advertiser  String
  budget      Float
  bidCpm      Float
  country     String
  deviceType  String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
}